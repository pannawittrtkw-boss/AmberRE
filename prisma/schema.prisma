generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Enums
// ==========================================

enum SubscriptionTier {
  STANDARD
  PRO
  ELITE
}

// ==========================================
// 1. Authentication & User Management
// ==========================================

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @db.VarChar(255)
  firstName     String    @db.VarChar(100)
  lastName      String    @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  role          String    @default("BUYER") @db.VarChar(20)
  language      String    @default("th") @db.VarChar(5)
  profileImage  String?   @db.VarChar(500)
  lineId        String?   @db.VarChar(100)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // B2B SaaS — subscription & agent website
  subscriptionTier  SubscriptionTier  @default(STANDARD)
  tierExpiredAt     DateTime?
  hasAgentWebsite   Boolean           @default(false)
  subdomain         String?           @unique @db.VarChar(100)
  customDomain      String?           @unique @db.VarChar(200)
  themeConfig       Json?

  properties         Property[]         @relation("OwnerProperties")
  agentProperties    Property[]         @relation("AgentProperties")
  articles           Article[]
  reviews            Review[]
  surveys            Survey[]
  coAgentApplication CoAgentApplication?
  agentCommissions   CommissionSharing[] @relation("AgentCommissions")
  coAgentCommissions CommissionSharing[] @relation("CoAgentCommissions")
  approvedCoAgents   CoAgentApplication[] @relation("ApprovedByUser")
  activityLogs       ActivityLog[]
  passwordResets     PasswordResetToken[]
  contracts          Contract[]
  contactUnlockLogs  ContactUnlockLog[]
  transactions       Transaction[]
  customerLeads      CustomerLead[]
}

model Contract {
  id              Int      @id @default(autoincrement())
  contractNumber  String   @unique @db.VarChar(50)

  // Dates
  contractDate    DateTime
  startDate       DateTime
  endDate         DateTime
  termMonths      Int      @default(12)

  // Lessor (ผู้ให้เช่า)
  lessorName        String   @db.VarChar(200)
  lessorNameEn      String?  @db.VarChar(200)
  lessorNationality String?  @db.VarChar(50)
  lessorIdCard      String?  @db.VarChar(50)
  lessorAddress     String?  @db.Text
  lessorAddressEn   String?  @db.Text
  lessorPhone       String?  @db.VarChar(50)

  // Lessee (ผู้เช่า)
  lesseeName        String   @db.VarChar(200)
  lesseeNameEn      String?  @db.VarChar(200)
  lesseeNationality String?  @db.VarChar(50)
  lesseeIdCard      String?  @db.VarChar(50) // ID card or passport
  lesseeAddress     String?  @db.Text
  lesseeAddressEn   String?  @db.Text
  lesseePhone       String?  @db.VarChar(50)

  // Joint Lessee (optional)
  jointLesseeName        String?  @db.VarChar(200)
  jointLesseeNameEn      String?  @db.VarChar(200)
  jointLesseeNationality String?  @db.VarChar(50)
  jointLesseeIdCard      String?  @db.VarChar(50)
  jointLesseeAddress     String?  @db.Text
  jointLesseeAddressEn   String?  @db.Text
  jointLesseePhone       String?  @db.VarChar(50)

  // Property
  propertyId      Int?
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  projectName     String   @db.VarChar(300)
  unitNumber      String   @db.VarChar(50)
  buildingName    String?  @db.VarChar(50)
  floorNumber     String?  @db.VarChar(20)
  propertyAddress   String   @db.Text
  propertyAddressEn String?  @db.Text
  sizeSqm           Decimal? @db.Decimal(10, 2)

  // Rent
  monthlyRent       Decimal @db.Decimal(18, 2)
  paymentDay        Int     @default(1) // pay by day X each month
  bankName          String? @db.VarChar(100)
  bankBranch        String? @db.VarChar(100)
  bankBranchEn      String? @db.VarChar(100)
  bankAccountName   String? @db.VarChar(200)
  bankAccountNameEn String? @db.VarChar(200)
  bankAccountNumber String? @db.VarChar(50)
  latePaymentFee    Decimal @default(500) @db.Decimal(10, 2)

  // Security deposit
  securityDeposit Decimal @db.Decimal(18, 2)

  // Furniture / Appliances (newline-separated text or JSON)
  furnitureList String? @db.Text
  applianceList String? @db.Text
  otherItems    String? @db.Text

  // "No items" markers — when true, the corresponding section is rendered
  // on the PDF as a blank checklist (all qty = 0) for the staff to fill
  // in manually. The matching list field is treated as empty in that
  // case, but is preserved in case the flag is later unticked.
  furnitureNone Boolean @default(false)
  applianceNone Boolean @default(false)
  otherItemsNone Boolean @default(false)

  // Custom clauses appended to section 11 of the contract. JSON array of
  // { th, en } pairs. Initialised on creation from the global default
  // template (SiteSetting "contract_default_clauses") but freely editable
  // per contract afterwards — edits do not flow back to the template.
  customClauses String? @db.Text

  // Per-clause overrides for the standard agreement. JSON map keyed by
  // clause key (e.g. "5.1") with { th?, en? } values. Snapshots from the
  // global standard template at creation; edits are local to this contract.
  clauseOverrides String? @db.Text

  // ID card images
  lessorIdImage      String? @db.Text
  lesseeIdImage      String? @db.Text
  jointLesseeIdImage String? @db.Text

  // Contract type
  contractType String @default("NEW") @db.VarChar(10) // NEW | RENEW

  // Deal type
  dealType      String  @default("DIRECT_OWNER") @db.VarChar(20) // DIRECT_OWNER | CO_AGENT
  coAgentName   String? @db.VarChar(200)
  coAgentPhone  String? @db.VarChar(50)
  coAgentLineId String? @db.VarChar(100)

  // Status
  status String @default("DRAFT") @db.VarChar(20) // DRAFT | ACTIVE | EXPIRED | TERMINATED

  // LINE notification group
  lineGroupId  String? @db.VarChar(100) // LINE Group ID for rent-due notifications

  // Signed contract upload & share
  signedPdfUrl String? @db.VarChar(500)
  shareToken   String? @unique @db.VarChar(100)

  // E-Sign — unique tokens sent to each party so they can sign online.
  // Signatures are stored as base64 data-URL PNGs drawn on a canvas.
  lessorSignToken       String?   @unique @db.VarChar(100)
  lesseeSignToken       String?   @unique @db.VarChar(100)
  jointLesseeSignToken  String?   @unique @db.VarChar(100)
  lessorSignature       String?   @db.Text
  lesseeSignature       String?   @db.Text
  jointLesseeSignature  String?   @db.Text
  lessorSignedAt        DateTime?
  lesseeSignedAt        DateTime?
  jointLesseeSignedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  rentPayments RentPayment[]

  @@index([propertyId])
  @@index([status])
}

model RentPayment {
  id         Int       @id @default(autoincrement())
  contractId Int
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  dueDate    DateTime
  amount     Decimal   @db.Decimal(18, 2)
  isPaid     Boolean   @default(false)
  paidAt     DateTime?
  note       String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([contractId, dueDate])
  @@index([dueDate])
  @@index([isPaid])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(100)
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ==========================================
// 2. Property Listing & Search
// ==========================================

model Property {
  id                Int      @id @default(autoincrement())
  titleTh           String   @db.VarChar(500)
  titleEn           String?  @db.VarChar(500)
  descriptionTh     String?  @db.Text
  descriptionEn     String?  @db.Text
  propertyType      String   @db.VarChar(20)
  buildingType      String   @default("NONE") @db.VarChar(20)
  listingType       String   @db.VarChar(20)
  condition         String?  @db.VarChar(20) // FIRST_HAND | SECOND_HAND (null for LAND)
  landSizeRai       Decimal? @db.Decimal(10, 2) // For LAND
  landSizeNgan      Decimal? @db.Decimal(10, 2) // For LAND
  landSizeWa        Decimal? @db.Decimal(10, 2) // For LAND
  price             Decimal  @db.Decimal(18, 2)
  priceUnit         String   @default("THB") @db.VarChar(10)
  sizeSqm           Decimal? @db.Decimal(10, 2)
  bedrooms          Int      @default(0)
  bathrooms         Int      @default(0)
  floor             Int?
  kitchenPartition  Boolean  @default(false)
  bedroomPartition  Boolean  @default(false)
  isFeatured        Boolean  @default(false)
  isPopular         Boolean  @default(false)
  isSold            Boolean  @default(false)
  fullyFurnished    Boolean  @default(false)
  fullyElectric     Boolean  @default(false)
  estCode           String?  @db.VarChar(50)
  availableDate     DateTime?
  addedAt           DateTime?
  salePrice         Decimal? @db.Decimal(18, 2)
  projectName       String?  @db.VarChar(300)
  address           String?  @db.VarChar(500)
  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(10, 7)
  views             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // New fields for property management form
  sourceLink          String?  @db.VarChar(500)
  linkPage            String?  @db.VarChar(500)
  building            String?  @db.VarChar(50)
  postFrom            String?  @default("OWNER") @db.VarChar(20)
  furnitureDetails    String?  @db.Text
  electricalAppliances String? @db.Text
  nearbyStations      String?  @db.Text
  facilities          String?  @db.Text
  ownerName           String?  @db.VarChar(200)
  ownerPhone          String?  @db.VarChar(50)
  ownerLineId         String?  @db.VarChar(100)
  ownerFacebookUrl    String?  @db.VarChar(500)
  coAgentName         String?  @db.VarChar(200)
  coAgentPhone        String?  @db.VarChar(50)
  coAgentLineId       String?  @db.VarChar(100)
  coAgentFacebookUrl  String?  @db.VarChar(500)
  status              String?  @default("PENDING") @db.VarChar(30)
  category            String?  @default("NORMAL") @db.VarChar(20)
  priority            String?  @default("NORMAL") @db.VarChar(20)
  foreignerAccept     String?  @default("ACCEPT") @db.VarChar(20)
  note                String?  @db.Text
  province            String?  @db.VarChar(100)
  district            String?  @db.VarChar(100)
  subdistrict         String?  @db.VarChar(100)
  isExclusive         Boolean  @default(false)
  exclusiveStartDate  DateTime?
  exclusiveEndDate    DateTime?

  // B2B SaaS
  coBrokeCommission   String?  @db.VarChar(50)
  isPremiumBoost      Boolean  @default(false)

  // Investment analysis (SALE / RENT_AND_SALE only)
  invPurchasePrice       Decimal? @db.Decimal(18, 2)
  invRenovationCost      Decimal? @db.Decimal(18, 2)
  invExpectedRentPerMonth Decimal? @db.Decimal(18, 2)
  invCommonFeePerYear    Decimal? @db.Decimal(18, 2)
  invMaintenancePerYear  Decimal? @db.Decimal(18, 2)
  invLandTaxRate         Decimal? @db.Decimal(8, 4)
  invVacancyMonths       Decimal? @db.Decimal(4, 2)
  invBrokerFeeMonths     Decimal? @db.Decimal(4, 2)
  invLoanAmount          Decimal? @db.Decimal(18, 2)
  invLoanTermYears       Decimal? @db.Decimal(5, 2)
  invLoanInterestRate    Decimal? @db.Decimal(6, 4)

  // AI-generated content tracking
  descriptionGeneratedAt DateTime?

  ownerId    Int
  owner      User   @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agentId    Int?
  agent      User?  @relation("AgentProperties", fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projectId  Int?
  project    Project? @relation(fields: [projectId], references: [id])

  images             PropertyImage[]
  propertyAmenities  PropertyAmenity[]
  propertyStations   PropertyStation[]
  reviews            Review[]
  commissions        CommissionSharing[]
  contracts          Contract[]
  contactUnlockLogs  ContactUnlockLog[]
}

model ContactUnlockLog {
  id           Int      @id @default(autoincrement())
  agentId      Int
  propertyId   Int
  unlockedAt   DateTime @default(now())

  agent    User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([agentId, propertyId])
  @@index([agentId])
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  imageUrl   String   @db.VarChar(500)
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Amenity {
  id     Int     @id @default(autoincrement())
  nameTh String  @db.VarChar(100)
  nameEn String  @db.VarChar(100)
  icon   String? @db.VarChar(100)

  propertyAmenities PropertyAmenity[]
}

model PropertyAmenity {
  propertyId Int
  amenityId  Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
}

model BTSMRTStation {
  id        Int     @id @default(autoincrement())
  nameTh    String  @db.VarChar(100)
  nameEn    String  @db.VarChar(100)
  line      String  @db.VarChar(50)
  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)

  propertyStations PropertyStation[]
}

model PropertyStation {
  propertyId Int
  stationId  Int
  distanceKm Decimal @db.Decimal(5, 2)

  property Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  station  BTSMRTStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@id([propertyId, stationId])
}

model Project {
  id            Int      @id @default(autoincrement())
  nameTh        String   @db.VarChar(300)
  nameEn        String?  @db.VarChar(300)
  descriptionTh String?  @db.Text
  descriptionEn String?  @db.Text
  developer     String?  @db.VarChar(200)
  imageUrl      String?  @db.VarChar(500)
  logoUrl       String?  @db.VarChar(500)
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  isPopular     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  // Location
  location      String?  @db.VarChar(300)
  fullAddress   String?  @db.Text
  province      String?  @db.VarChar(100)
  district      String?  @db.VarChar(100)
  projectArea   String?  @db.VarChar(200)
  googleMapsUrl String?  @db.VarChar(500)

  // Building details
  ceilingHeight Decimal? @db.Decimal(5, 2)
  utilityFee    String?  @db.VarChar(100)
  buildings     Int?
  parking       Int?
  floors        Int?
  totalUnits    Int?
  yearCompleted Int?

  // JSON fields
  facilities    String?  @db.Text // JSON array of facility keys
  unitTypes     String?  @db.Text // JSON array of {type, size, planImageUrl}
  photoAlbum    String?  @db.Text // JSON array of image URLs
  nearbyPlaces  String?  @db.Text // JSON array of {name, distance, type}

  properties Property[]
}

model Portfolio {
  id            Int      @id @default(autoincrement())
  titleTh       String   @db.VarChar(300)
  titleEn       String?  @db.VarChar(300)
  descriptionTh String?  @db.Text
  descriptionEn String?  @db.Text
  imageUrl      String?  @db.VarChar(500)
  createdAt     DateTime @default(now())
}

model SuccessStory {
  id               Int      @id @default(autoincrement())
  titleTh          String   @db.VarChar(300)
  titleEn          String?  @db.VarChar(300)
  contentTh        String?  @db.Text
  contentEn        String?  @db.Text
  imageUrl         String?  @db.VarChar(500)
  propertyImageUrl String?  @db.VarChar(500)
  category         String   @default("RENT_CONDO") @db.VarChar(50)
  createdAt        DateTime @default(now())
}

model CoAgentApplication {
  id              Int      @id @default(autoincrement())
  companyName     String?  @db.VarChar(300)
  licenseNumber   String?  @db.VarChar(100)
  experienceYears Int?
  status          String   @default("PENDING") @db.VarChar(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId     Int  @unique
  user       User @relation(fields: [userId], references: [id])
  approvedBy Int?
  approver   User? @relation("ApprovedByUser", fields: [approvedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model CommissionSharing {
  id             Int      @id @default(autoincrement())
  commissionRate Decimal  @db.Decimal(5, 2)
  agentShare     Decimal  @db.Decimal(5, 2)
  coAgentShare   Decimal  @db.Decimal(5, 2)
  status         String   @default("PENDING") @db.VarChar(20)
  createdAt      DateTime @default(now())

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  agentId    Int
  agent      User     @relation("AgentCommissions", fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  coAgentId  Int
  coAgent    User     @relation("CoAgentCommissions", fields: [coAgentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ArticleCategory {
  id     Int    @id @default(autoincrement())
  nameTh String @db.VarChar(100)
  nameEn String @db.VarChar(100)
  slug   String @unique @db.VarChar(100)

  articles Article[]
}

model Article {
  id            Int      @id @default(autoincrement())
  titleTh       String   @db.VarChar(500)
  titleEn       String?  @db.VarChar(500)
  contentTh     String?  @db.Text
  contentEn     String?  @db.Text
  slug          String   @unique @db.VarChar(200)
  featuredImage String?  @db.VarChar(500)
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoryId Int
  category   ArticleCategory @relation(fields: [categoryId], references: [id])
  authorId   Int
  author     User            @relation(fields: [authorId], references: [id])
}

model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      @db.SmallInt
  comment    String?  @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Survey {
  id        Int      @id @default(autoincrement())
  rating    Int      @db.SmallInt
  feedback  String?  @db.Text
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  subject   String?  @db.VarChar(300)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscription {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(255)
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
}

model SocialMediaLink {
  id       Int     @id @default(autoincrement())
  platform String  @db.VarChar(50)
  url      String  @db.VarChar(500)
  isActive Boolean @default(true)
}

model SiteSetting {
  id      Int     @id @default(autoincrement())
  key     String  @unique @db.VarChar(100)
  valueTh String? @db.Text
  valueEn String? @db.Text
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(50)
  entityId   Int?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

// ==========================================
// Accounting
// ==========================================

model Transaction {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Decimal  @db.Decimal(12, 2)
  type        String   @db.VarChar(20) // INCOME | EXPENSE
  recordType  String   @default("ACTUAL") @db.VarChar(20) // ACTUAL | FORECAST
  category    String   @db.VarChar(100)
  description String   @db.Text
  payee       String?  @db.VarChar(100)
  slipUrl     String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([type, recordType])
  @@index([createdById])
}

model Shareholder {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  share     Decimal  @default(25) @db.Decimal(5, 2) // percentage
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==========================================
// Customer Lead & Matching
// ==========================================

model CustomerLead {
  id          Int      @id @default(autoincrement())
  name        String?  @db.VarChar(200)
  phone       String?  @db.VarChar(50)
  lineId      String?  @db.VarChar(100)
  facebook    String?  @db.VarChar(200)
  projectName String?  @db.VarChar(300)
  province    String?  @db.VarChar(100)
  district    String?  @db.VarChar(100)
  subdistrict String?  @db.VarChar(100)
  btsStation  String?  @db.VarChar(200)
  budgetMin   Decimal? @db.Decimal(18, 2)
  budgetMax   Decimal? @db.Decimal(18, 2)
  bedrooms    Int?
  note        String?  @db.Text
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([status])
}

model LineUrlHistory {
  id         Int       @id @default(autoincrement())
  groupId    String    @db.VarChar(100)
  url        String    @db.Text
  sentBy     String?   @db.VarChar(100)
  userId     String?   @db.VarChar(100)
  sentAt     DateTime  @default(now())
  dateKey    String    @default("") @db.VarChar(10)
  dailySeq   Int       @default(0)
  // PENDING | NOT_ACCEPT_AGENT | ACCEPT_AGENT_NOT_FOREIGNER | ACCEPT_ALL | UNABLE_TO_CONTACT | WAIT_FOR_REPLY | NOT_AVAILABLE
  status     String    @default("PENDING") @db.VarChar(40)
  reviewedAt DateTime?
  reviewedBy String?   @db.VarChar(100)
  quoteToken    String?   @db.VarChar(300)
  originalMsgId String?   @db.VarChar(100)
  botMsgId      String?   @db.VarChar(100)

  @@unique([groupId, url])
  @@index([groupId])
  @@index([groupId, status])
  @@index([groupId, dateKey])
  @@index([originalMsgId])
}

// Maps original user message IDs to bot-sent translation message IDs so
// the bot can delete its translation when the original is unsent.
model LineBotTranslation {
  id            Int      @id @default(autoincrement())
  originalMsgId String   @unique @db.VarChar(100)
  botMsgId      String   @db.VarChar(100)
  groupId       String   @db.VarChar(100)
  createdAt     DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

// ==========================================
// AI Office
// ==========================================

model AiAgent {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  position   String   @db.VarChar(100)
  duties     String   @db.Text
  icon       String   @default("🤖") @db.VarChar(10)
  color      String   @default("#6366f1") @db.VarChar(20)
  isActive   Boolean  @default(true)
  actionType String   @default("NONE") @db.VarChar(30)
  appearance String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LineUrlDuplicate {
  id          Int      @id @default(autoincrement())
  groupId     String   @db.VarChar(100)
  url         String   @db.Text
  sentBy      String?  @db.VarChar(100)
  attemptedAt DateTime @default(now())
  dateKey     String   @db.VarChar(10)

  @@index([groupId, dateKey])
}

// ==========================================
// Accounting Documents
// ==========================================

model AccountingCompany {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(200)
  nameEn         String?  @db.VarChar(200)
  address        String?  @db.Text
  addressEn      String?  @db.Text
  taxId          String?  @db.VarChar(50)
  phone          String?  @db.VarChar(50)
  logoUrl           String?  @db.VarChar(500)
  signatureUrl      String?  @db.VarChar(500)
  authorizedName    String?  @db.VarChar(200)
  authorizedNameEn  String?  @db.VarChar(200)
  bankName          String?  @db.VarChar(100)
  bankNameEn        String?  @db.VarChar(100)
  bankAccountNumber String?  @db.VarChar(50)
  bankAccountName   String?  @db.VarChar(200)
  bankAccountNameEn String?  @db.VarChar(200)
  swiftCode         String?  @db.VarChar(20)
  bankBranchName    String?  @db.VarChar(200)
  bankAddress       String?  @db.Text
  currency          String   @default("THB") @db.VarChar(10)
  updatedAt         DateTime @updatedAt
}

model AccCustomer {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  address     String?  @db.Text
  taxId       String?  @db.VarChar(50)
  phone       String?  @db.VarChar(50)
  email       String?  @db.VarChar(200)
  contactName String?  @db.VarChar(200)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoices     AccInvoice[]
  billingNotes AccBillingNote[]
  receipts     AccReceipt[]
}

model AccInvoice {
  id           Int       @id @default(autoincrement())
  docNumber    String    @unique @db.VarChar(50)
  date         DateTime
  dueDate      DateTime?
  // Credit term used to auto-calc dueDate from date, e.g. "0" (cash/due on
  // receipt), "7", "15", "30", "45", "60" (days). Null/empty means dueDate
  // was set manually (custom) — not shown on the PDF.
  creditTerm   String?   @db.VarChar(20)
  customerId   Int
  customer     AccCustomer @relation(fields: [customerId], references: [id])
  items        Json
  subtotal     Decimal   @db.Decimal(15,2)
  vatRate      Decimal   @default(7) @db.Decimal(5,2)
  vatAmount    Decimal   @db.Decimal(15,2)
  totalAmount  Decimal   @db.Decimal(15,2)
  note         String?   @db.Text
  status       String    @default("PENDING") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  billingNotes AccBillingNote[]
  receipts     AccReceipt[]
}

model AccBillingNote {
  id           Int       @id @default(autoincrement())
  docNumber    String    @unique @db.VarChar(50)
  date         DateTime
  dueDate      DateTime?
  customerId   Int
  customer     AccCustomer @relation(fields: [customerId], references: [id])
  invoiceId    Int?
  invoice      AccInvoice? @relation(fields: [invoiceId], references: [id])
  items        Json
  subtotal     Decimal   @db.Decimal(15,2)
  vatRate      Decimal   @default(7) @db.Decimal(5,2)
  vatAmount    Decimal   @db.Decimal(15,2)
  totalAmount  Decimal   @db.Decimal(15,2)
  note         String?   @db.Text
  status       String    @default("PENDING") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  receipts     AccReceipt[]
}

model AccReceipt {
  id              Int       @id @default(autoincrement())
  docNumber       String    @unique @db.VarChar(50)
  date            DateTime
  customerId      Int
  customer        AccCustomer @relation(fields: [customerId], references: [id])
  billingNoteId   Int?
  billingNote     AccBillingNote? @relation(fields: [billingNoteId], references: [id])
  invoiceId       Int?
  invoice         AccInvoice? @relation(fields: [invoiceId], references: [id])
  items           Json
  subtotal        Decimal   @db.Decimal(15,2)
  vatRate         Decimal   @default(7) @db.Decimal(5,2)
  vatAmount       Decimal   @db.Decimal(15,2)
  totalAmount     Decimal   @db.Decimal(15,2)
  paymentMethod   String    @default("CASH") @db.VarChar(20)
  note            String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
